      <pubDate>Mon, 08 Jul 2026 00:00:00 +0000</pubDate>
      <enclosure
        url="https://github.com/komikku-app/anikku/releases/download/v1.0.1/Anikku-1.0.1.dmg"
        sparkle:edSignature="BASE64_EDDSA_SIGNATURE"
        length="TOTAL_BYTES"
        type="application/octet-stream" />
      <sparkle:releaseNotesLink>
        https://github.com/komikku-app/anikku/releases/tag/v1.0.1
      </sparkle:releaseNotesLink>
    </item>

    -->
  </channel>
</rss>
